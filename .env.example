# HAIP Environment Variables
# Copy to .env for local development

# Database
DATABASE_URL=postgresql://haip:haip@localhost:5432/haip

# Redis
REDIS_URL=redis://localhost:6379

# API
PORT=3000
NODE_ENV=development

# Authentication (Keycloak OIDC)
# AUTH_ENABLED controls whether JWT auth is enforced:
#   false (default) — all requests pass through, no JWT required. Use for dev/testing.
#   true            — valid JWT required on all endpoints except @Public().
AUTH_ENABLED=false
KEYCLOAK_URL=http://localhost:8080

# Connect API (OTAIP agents) — comma-separated list of valid API keys.
# When AUTH_ENABLED != 'false' and this is unset/empty, ConnectController
# returns 500 (fail closed). When AUTH_ENABLED=false, the guard is bypassed.
# CONNECT_API_KEY=agent1-key,agent2-key
KEYCLOAK_REALM=haip
KEYCLOAK_CLIENT_ID=haip-api
# KEYCLOAK_AUDIENCE — optional explicit override for the expected `aud` claim.
# If unset, KEYCLOAK_CLIENT_ID is used. JWTs whose `aud`/`azp` does not match
# this value are rejected (prevents cross-client token replay within the realm).
# KEYCLOAK_AUDIENCE=haip-api

# Stripe Payment Gateway
# STRIPE_MODE controls which gateway is used:
#   mock (default) — no HTTP calls, fake success. Use for tests/CI.
#   test           — real Stripe calls in test mode. Requires STRIPE_SECRET_KEY.
#   live           — real charges. Requires STRIPE_SECRET_KEY.
STRIPE_MODE=mock
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
