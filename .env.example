# HAIP Environment Variables
# Copy to .env for local development

# Database
DATABASE_URL=postgresql://haip:haip@localhost:5432/haip

# Redis
REDIS_URL=redis://localhost:6379

# API
PORT=3000
NODE_ENV=development

# Auth (OAuth 2.0 / OpenID Connect — configure in Phase 1+)
# AUTH_ISSUER_URL=
# AUTH_CLIENT_ID=
# AUTH_CLIENT_SECRET=

# Payment Gateway (PCI compliant — Stripe tokenization, never raw card data)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
