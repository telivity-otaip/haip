{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API Server",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["apps/api/start-dev.mjs"],
      "port": 3000
    },
    {
      "name": "Dashboard",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["apps/dashboard/node_modules/vite/bin/vite.js", "--config", "apps/dashboard/vite.config.ts"],
      "port": 5173
    }
  ]
}
